{
  "name": "living-location-heatmap",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A private, client-side living-location heatmap for exploring neighbourhood suitability from personal amenity preferences.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint ."
  },
  "keywords": [
    "maps",
    "osm",
    "heatmap",
    "housing",
    "amsterdam"
  ],
  "author": "Oli Payne",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
